include /shared/components/index
include /shared/shell/index
include /shared/sections/common/feature-grid

mixin notFoundSections(params)
  -
    const p = params || {}
  +featureGrid({
    className: ['not-found-sections', p.className || ''].filter(Boolean).join(' '),
    eyebrow: p.eyebrow,
    title: p.title,
    text: p.text,
    align: 'center',
    columns: 4,
    items: p.items
  })
