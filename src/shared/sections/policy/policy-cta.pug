include /shared/components/index
include /shared/shell/index
include /shared/sections/common/cta-section

mixin policyCta(params)
  -
    const p = params || {}
  +ctaSection({
    className: ['policy-cta', p.className || ''].filter(Boolean).join(' '),
    title: p.title,
    text: p.text,
    action: p.action,
    image: p.image,
    imageAlt: p.imageAlt,
    imageWidth: p.imageWidth,
    imageHeight: p.imageHeight
  })
