include /shared/shell/index

mixin aboutProcess(params)
  -
    const p = params || {}
    const eyebrow = p.eyebrow || null
    const title = p.title || ''
    const text = p.text || null
    const steps = Array.isArray(p.steps) ? p.steps : []
    const className = p.className || ''
    const rootClasses = ['about-process', className].filter(Boolean).join(' ')

  +sectionShell({
    tag: 'section',
    variant: 'none',
    spacing: 'md',
    container: 'default',
    className: rootClasses,
    containerClassName: 'about-process__container'
  })
    .about-process__panel
      .about-process__header
        if eyebrow
          p.about-process__eyebrow= eyebrow
        h2.about-process__title= title
        if text
          p.about-process__text= text

      if steps.length
        .about-process__steps
          each step in steps
            article.about-process__step
              p.about-process__step-number= step.number
              h3.about-process__step-title= step.title
              p.about-process__step-text= step.text
