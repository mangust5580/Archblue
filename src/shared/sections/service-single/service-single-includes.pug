include /shared/components/index
include /shared/shell/index
include /shared/sections/common/feature-grid

mixin serviceSingleIncludes(params)
  -
    const p = params || {}
  +featureGrid({
    className: ['service-single-includes', p.className || ''].filter(Boolean).join(' '),
    eyebrow: p.eyebrow,
    title: p.title,
    text: p.text,
    align: 'start',
    columns: 3,
    items: p.items
  })
