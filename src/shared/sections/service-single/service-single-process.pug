include /shared/components/index
include /shared/shell/index

mixin serviceSingleProcess(params)
  -
    const p = params || {}
    const eyebrow = p.eyebrow || null
    const title = p.title || ''
    const text = p.text || null
    const steps = Array.isArray(p.steps) ? p.steps : []
    const className = p.className || ''
    const rootClasses = ['service-single-process', className].filter(Boolean).join(' ')

  +sectionShell({
    tag: 'section',
    variant: 'none',
    spacing: 'md',
    container: 'default',
    className: rootClasses,
    containerClassName: 'service-single-process__container'
  })
    .service-single-process__panel
      .service-single-process__header
        if eyebrow
          p.service-single-process__eyebrow= eyebrow
        h2.service-single-process__title= title
        if text
          p.service-single-process__text= text

      if steps.length
        .service-single-process__steps
          each step in steps
            article.service-single-process__step
              p.service-single-process__step-number= step.number
              h3.service-single-process__step-title= step.title
              p.service-single-process__step-text= step.text
