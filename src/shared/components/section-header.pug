mixin sectionHeader(params)
  -
    const p = params || {}
    const title = p.title || ''
    const eyebrow = p.eyebrow || null
    const text = p.text || null
    const validLevels = [2, 3, 4, 5, 6]
    const level = validLevels.includes(p.headingLevel) ? p.headingLevel : 2
    const headingTag = 'h' + level
    const action = (p.action && p.action.href) ? p.action : null
    const validAligns = ['between', 'start', 'center']
    const align = validAligns.includes(p.align) ? p.align : 'between'
    const extraClass = p.className || ''
    const cls = [
      'section-header',
      'section-header--' + align,
      action ? 'section-header--has-action' : '',
      extraClass
    ].filter(Boolean).join(' ')

  div(class=cls)
    .section-header__content
      if eyebrow
        p.section-header__eyebrow= eyebrow
      #{headingTag}.section-header__title= title
      if text
        p.section-header__text= text
    if action
      a.section-header__action(
        href=action.href
        aria-label=action.ariaLabel || false
      )
        span.section-header__action-text= action.text
        if action.icon
          span.section-header__action-icon(aria-hidden='true')
            +icon({ name: 'ui-arrow-right', size: 'sm', decorative: true })
