extends /shared/layouts/base.pug

block vars
  - var pageTitle = 'Страница не найдена'
  - var pageDescription = 'Страница не найдена. Навигация к основным разделам сайта Archblue.'
  - var pageUrl = '404.html'

block head
  meta(name='robots' content='noindex')

include /shared/sections/not-found/not-found-hero
include /shared/sections/not-found/not-found-sections

block content
  +notFoundHero({
    eyebrow: '404',
    title: 'Страница не найдена',
    text: 'К сожалению, запрашиваемая страница не существует или была перемещена. Попробуйте перейти на главную или воспользуйтесь разделами ниже.',
    actions: [
      { text: 'На главную', variant: 'primary', href: 'index.html', icon: true },
      { text: 'Все проекты', variant: 'outline', href: 'projects.html' }
    ],
    image: 'images/articles/trends-2024/cover.jpg',
    imageAlt: 'Современный дом с вечерней подсветкой и панорамным остеклением',
    imageWidth: 1448,
    imageHeight: 1086
  })

  +notFoundSections({
    title: 'Полезные разделы',
    items: [
      {
        icon: 'services-residential',
        title: 'Проекты',
        text: 'Изучите реализованные проекты и вдохновитесь идеями.',
        href: 'projects.html'
      },
      {
        icon: 'services-architecture',
        title: 'Услуги',
        text: 'Мы предлагаем полный цикл архитектурного проектирования.',
        href: 'services.html'
      },
      {
        icon: 'common-layers',
        title: 'Статьи',
        text: 'Полезные материалы об архитектуре, дизайне и строительстве.',
        href: 'articles.html'
      },
      {
        icon: 'stats-users',
        title: 'О нас',
        text: 'Узнайте больше о нашей студии и подходе к работе.',
        href: 'about.html'
      }
    ]
  })
