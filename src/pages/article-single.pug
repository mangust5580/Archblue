extends /shared/layouts/base.pug

block vars
  - var activeNav = 'articles'
  - var pageTitle = 'Тренды в архитектуре 2024: что действительно важно'
  - var pageDescription = 'Материал Archblue о тенденциях архитектуры, подходах к среде и проектных решениях.'
  - var pageUrl = 'article-single.html'

include /shared/sections/article-single/article-single-hero
include /shared/sections/article-single/article-single-content
include /shared/sections/article-single/article-single-related
include /shared/sections/article-single/article-single-cta
include /shared/modals/project-modal
include /shared/modals/thank-you-modal

block content
  +articleSingleHero({
    breadcrumbs: [
      { label: 'Главная', href: 'index.html' },
      { label: 'Статьи', href: 'articles.html' },
      { label: 'Тренды в архитектуре 2024' }
    ],
    category: 'Архитектура',
    date: '15 мая 2024',
    datetime: '2024-05-15',
    readTime: '6 мин чтения',
    title: 'Тренды в архитектуре 2024: что действительно важно',
    text: 'Архитектура продолжает меняться под влиянием технологий, экологических вызовов и новых ожиданий людей. Разбираем ключевые тренды, которые формируют архитектурную среду уже сегодня.',
    image: 'images/articles/trends-2024/hero.jpg',
    imageAlt: 'Современная вилла с панорамным остеклением и природным ландшафтом',
    imageWidth: 1448,
    imageHeight: 1086
  })

  +articleSingleContent({
    lead: {
      image: 'images/articles/trends-2024/lead.jpg',
      imageAlt: 'Фасад современного здания с зелёными террасами',
      imageWidth: 1448,
      imageHeight: 1086,
      heading: 'Устойчивость и экологичность',
      paragraphs: [
        'Экологическая повестка перестала быть опцией — она стала обязательной частью любого серьёзного архитектурного проекта. Пассивные дома, зелёные кровли, использование местных материалов и солнечная генерация сегодня присутствуют не только в экспериментальных, но и в типовых объектах.',
        'Архитекторы переосмысляют жизненный цикл здания с самого начала: от выбора фундамента до адаптации к будущим климатическим изменениям. Устойчивость — это уже не дополнительный слой, а несущая конструкция концепции.'
      ]
    },
    blocks: [
      {
        heading: 'Гибкие и адаптивные пространства',
        paragraphs: [
          'Пандемия окончательно переписала правила: люди хотят пространств, которые меняются вместе с ними. Офисы с трансформируемыми перегородками, квартиры с нейтральными комнатами, коммерческие здания, которые можно перепрофилировать за несколько месяцев.',
          'Архитекторы проектируют не под функцию, а под сценарий — и закладывают возможность смены сценариев. Это меняет подход к конструктиву, инженерии и зонированию.'
        ]
      },
      {
        heading: 'Технологии как часть архитектуры',
        paragraphs: [
          'BIM, параметрическое проектирование, AR-визуализация на стройке — всё это перестаёт быть инструментом избранных студий. Автоматизация ускоряет цикл разработки и снижает число ошибок на этапе строительства.',
          'Умные системы всё чаще встраиваются в здание с нулевой отметки, а не накладываются поверх. Архитектура и технологии перестают быть параллельными процессами.'
        ]
      },
      {
        heading: 'Человек в центре',
        paragraphs: [
          'После десятилетий увлечения формой и технологиями архитектура возвращается к человеческому масштабу. Нейробиология пространства, тактильность материалов, инсоляция и акустика снова становятся приоритетами при проектировании.',
          'В общественных зданиях и городской среде усиливается внимание к тому, как пространство влияет на состояние и поведение людей. Архитектура снова задаётся вопросом: как здесь живётся?'
        ]
      }
    ],
    aside: {
      image: 'images/articles/trends-2024/aside.jpg',
      imageAlt: 'Минималистичный интерьер с натуральными материалами и видом на природу',
      imageWidth: 1448,
      imageHeight: 1086,
      quote: 'Архитектура будущего — это не про форму. Это про отношения между человеком, пространством и природой.',
      quoteAuthor: '— Архитектор Archblue',
      takeaways: {
        heading: 'Ключевые выводы',
        items: [
          'Устойчивые материалы и пассивная энергетика становятся новым стандартом',
          'Гибкие планировки заменяют жёсткое зонирование',
          'Технологии встраиваются в архитектуру с нулевой отметки',
          'Человеческий масштаб возвращается в большие общественные пространства'
        ]
      }
    },
    author: {
      name: 'Анна Морозова',
      role: 'Главный архитектор Archblue',
      date: '15 мая 2024',
      datetime: '2024-05-15',
      readTime: '6 мин чтения',
      image: 'images/shared/avatars/anna-morozova.jpg',
      imageAlt: 'Анна Морозова, главный архитектор Archblue',
      imageWidth: 512,
      imageHeight: 512,
      initials: 'АМ'
    },
    tags: ['архитектура', 'тренды', 'устойчивость', 'интерьеры', 'технологии'],
    share: {
      label: 'Поделиться:',
      actions: [
        { network: 'telegram', label: 'Поделиться в Telegram' },
        { network: 'x', label: 'Поделиться в X' },
        { network: 'facebook', label: 'Поделиться в Facebook' },
        { network: 'mail', label: 'Поделиться по почте' }
      ]
    }
  })

  +articleSingleRelated({
    title: 'Похожие статьи',
    items: [
      {
        image: 'images/articles/private-house-architecture/card.jpg',
        imageAlt: 'Современный частный дом с продуманной архитектурой',
        date: '12 июн 2024',
        readTime: '6 мин чтения',
        category: 'Архитектура',
        title: 'Как выбрать архитектора для частного дома',
        text: 'На что обратить внимание при выборе архитектора. Какие вопросы задать на старте и как избежать типичных ошибок.',
        href: 'article-single.html',
        linkText: 'Читать',
        imageWidth: 800,
        imageHeight: 500
      },
      {
        image: 'images/articles/minimalism-interior/card.jpg',
        imageAlt: 'Светлый минималистичный интерьер с натуральным деревом',
        date: '8 мая 2024',
        readTime: '5 мин чтения',
        category: 'Интерьеры',
        title: 'Минимализм в интерьере: больше, чем стиль',
        text: 'Разбираем принципы минимализма, его преимущества и как создать гармоничное функциональное пространство.',
        href: 'article-single.html',
        linkText: 'Читать',
        imageWidth: 800,
        imageHeight: 500
      },
      {
        image: 'images/articles/natural-materials/card.jpg',
        imageAlt: 'Архитектурный фрагмент с деревом, камнем и стеклом',
        date: '5 мая 2024',
        readTime: '5 мин чтения',
        category: 'Материалы',
        title: 'Натуральные материалы в современной архитектуре',
        text: 'Дерево, камень, бетон, глина и стекло — как природные материалы формируют устойчивую эстетику в архитектуре.',
        href: 'article-single.html',
        linkText: 'Читать',
        imageWidth: 800,
        imageHeight: 500
      }
    ]
  })

  +articleSingleCta({
    title: 'Хотите обсудить будущий проект?',
    text: 'Расскажите нам о задаче — поможем сформировать идею, подобрать подход и определить следующий шаг.',
    action: {
      text: 'Обсудить проект',
      modalTarget: 'project-modal',
      icon: false
    },
    image: 'images/shared/cta/cta.jpg',
    imageAlt: 'Современное архитектурное пространство',
    imageWidth: 836,
    imageHeight: 471
  })

  +projectModal()
  +thankYouModal()
